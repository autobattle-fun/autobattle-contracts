{
  "compilerOptions": {
    "types":       ["mocha", "chai"],
    "lib":         ["es2015"],
    "module":      "commonjs",
    "target":      "es6",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict":      true,
    "noImplicitAny": true,
    "outDir":      "dist"
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules"]
}
